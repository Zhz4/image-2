# 后端服务监听端口。前端 Vite 代理会把 /api 请求转发到这里。
PORT=3002

# OpenAI 或 OpenAI 兼容服务的 API Key。
OPENAI_API_KEY=

# OpenAI 兼容接口地址；使用官方 OpenAI 时可留空或删除。
OPENAI_BASE_URL=

# 图像生成模型名称。留空时后端默认使用 gpt-image-1。
OPENAI_IMAGE_MODEL=

# OpenAI 请求超时时间，单位毫秒。生图较慢时可适当调大。
OPENAI_REQUEST_TIMEOUT_MS=600000

# 生图并发张数限制。同一时间最多只会有这么多张图片在生成，超过的图片会进入队列等待。
IMAGE_GENERATION_CONCURRENCY=10

# 单个用户最多同时拥有的未完成生图任务数，包含等待中和生成中。
IMAGE_GENERATION_MAX_ACTIVE_TASKS_PER_USER=2

# 前端提交前拦截使用的同一上限。需要和 IMAGE_GENERATION_MAX_ACTIVE_TASKS_PER_USER 保持一致。
VITE_IMAGE_GENERATION_MAX_ACTIVE_TASKS_PER_USER=2

# Cloudflare R2 对象存储——生成的图片会在返回给前端前上传到这里。
# 生成后前端收到的 src 是 R2 的公开 URL，而非临时的 OpenAI URL。
# Cloudflare 账号 ID，可在 R2 API 令牌或账户概览里查看。
CLOUDFLARE_R2_ACCOUNT_ID=
# R2 API Token 的 Access Key ID，需要有目标桶的对象写入权限。
CLOUDFLARE_R2_ACCESS_KEY_ID=
# R2 API Token 的 Secret Access Key，只会在创建密钥时显示一次。
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
# R2 存储桶名称，例如 image-2。
CLOUDFLARE_R2_BUCKET_NAME=
# R2 存储桶的公开访问地址，例如 https://pub-xxx.r2.dev 或自定义域名。
CLOUDFLARE_R2_PUBLIC_URL=
# Cloudflare D1 账号 ID，通常与 CLOUDFLARE_R2_ACCOUNT_ID 是同一个账号 ID。
CLOUDFLARE_D1_ACCOUNT_ID=

# Cloudflare D1 数据库 ID，可在 D1 数据库详情页或 wrangler d1 list 中查看。
CLOUDFLARE_D1_DATABASE_ID=

# Cloudflare API Token，需要具备目标 D1 数据库的读取和写入权限。
CLOUDFLARE_D1_API_TOKEN=

# 登录 JWT 签名密钥，生产环境请使用足够长的随机字符串。
JWT_SECRET=

# 登录 token 有效期，单位秒；604800 等于 7 天。
JWT_EXPIRES_IN_SECONDS=604800
