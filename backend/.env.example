# 后端服务监听端口。前端 Vite 代理会把 /api 请求转发到这里。
PORT=3002

# OpenAI 或 OpenAI 兼容服务的 API Key。
OPENAI_API_KEY=

# OpenAI 兼容接口地址；使用官方 OpenAI 时可留空或删除。
OPENAI_BASE_URL=

# 图像生成模型名称。留空时后端默认使用 gpt-image-1。
OPENAI_IMAGE_MODEL=

# OpenAI 请求超时时间，单位毫秒。生图较慢时可适当调大。
OPENAI_REQUEST_TIMEOUT_MS=600000

# 生图并发张数限制。同一时间最多只会有这么多张图片在生成，超过的图片会进入队列等待。
IMAGE_GENERATION_CONCURRENCY=2
