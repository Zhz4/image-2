# 服务器部署环境变量。复制为 .env.prod 后填写真实值：
# cp .env.prod.example .env.prod

# 对外访问端口。默认 http://服务器IP:8080；如果要直接用 80，就改成 80。
APP_PORT=8080

# 后端容器监听端口。通常保持 3002，前端 Nginx 容器会把 /api 转发到这里。
PORT=3002

# OpenAI 或 OpenAI 兼容服务的 API Key。
OPENAI_API_KEY=

# OpenAI 兼容接口地址；使用官方 OpenAI 时可留空。
OPENAI_BASE_URL=

# 图像生成模型名称。留空时后端默认使用 gpt-image-1。
OPENAI_IMAGE_MODEL=

# OpenAI 请求超时时间，单位毫秒。生图较慢时可适当调大。
OPENAI_REQUEST_TIMEOUT_MS=600000

# 生图并发张数限制。
IMAGE_GENERATION_CONCURRENCY=2

# Cloudflare 账号 ID，可在 R2 API 令牌或账户概览里查看。
CLOUDFLARE_R2_ACCOUNT_ID=

# R2 API Token 的 Access Key ID，需要有目标桶的对象写入权限。
CLOUDFLARE_R2_ACCESS_KEY_ID=

# R2 API Token 的 Secret Access Key，只会在创建密钥时显示一次。
CLOUDFLARE_R2_SECRET_ACCESS_KEY=

# R2 存储桶名称，例如 image-2。
CLOUDFLARE_R2_BUCKET_NAME=

# R2 存储桶的公开访问地址，例如 https://pub-xxx.r2.dev 或自定义域名。
CLOUDFLARE_R2_PUBLIC_URL=
